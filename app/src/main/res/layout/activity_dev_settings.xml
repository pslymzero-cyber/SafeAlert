<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 송수신 설정 -->
        <TextView android:text="송수신 모드" android:textStyle="bold" android:textSize="16sp"
            android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp"/>
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="8dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">

                <TextView android:text="🚛 장비 작업자" android:textStyle="bold"
                    android:textSize="13sp" android:textColor="#374151"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginTop="10dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:text="신호 송신 (TX)" android:textSize="13sp"
                            android:textColor="#111827"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:text="BLE 신호를 주변에 송출"
                            android:textSize="11sp" android:textColor="#9CA3AF"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                    <Switch android:id="@+id/switch_device_tx"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginTop="12dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:text="신호 수신 (RX)" android:textSize="13sp"
                            android:textColor="#111827"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:text="주변 장비·보행자 감지"
                            android:textSize="11sp" android:textColor="#9CA3AF"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                    <Switch android:id="@+id/switch_device_rx"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

                <!-- 보행자끼리 경보 -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginTop="12dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:text="보행자끼리 경보" android:textSize="13sp"
                            android:textColor="#111827"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:text="보행자가 다른 보행자를 감지해도 경보 (기본: OFF)"
                            android:textSize="11sp" android:textColor="#9CA3AF"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                    <Switch android:id="@+id/switch_walker_detects_walker"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#F3F4F6" android:layout_marginTop="16dp" android:layout_marginBottom="4dp"/>

                <TextView android:text="🚶 보행자" android:textStyle="bold"
                    android:textSize="13sp" android:textColor="#374151"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginTop="10dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:text="신호 송신 (TX)" android:textSize="13sp"
                            android:textColor="#111827"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:text="BLE 신호를 주변에 송출 (기본: OFF)"
                            android:textSize="11sp" android:textColor="#9CA3AF"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                    <Switch android:id="@+id/switch_walker_tx"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginTop="12dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:text="신호 수신 (RX)" android:textSize="13sp"
                            android:textColor="#111827"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:text="주변 장비 감지"
                            android:textSize="11sp" android:textColor="#9CA3AF"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                    <Switch android:id="@+id/switch_walker_rx"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- BLE 설정 -->
        <TextView android:text="BLE 설정" android:textStyle="bold" android:textSize="16sp"
            android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp"/>
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="8dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:text="스캔 주기" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <Spinner android:id="@+id/spinner_scan_period" android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:entries="@array/scan_period_labels"/>
                <TextView android:text="광고 간격" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp"/>
                <Spinner android:id="@+id/spinner_advertise" android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:entries="@array/advertise_labels"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 경보 볼륨 -->
        <TextView android:text="경보 볼륨" android:textStyle="bold" android:textSize="16sp"
            android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp"/>
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="8dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:text="알람 볼륨 게인"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:textSize="13sp" android:textColor="#111827"/>
                    <TextView android:id="@+id/tv_alarm_volume_val"
                        android:layout_width="48dp" android:layout_height="wrap_content"
                        android:gravity="end" android:textSize="13sp" android:textColor="#374151"/>
                </LinearLayout>
                <TextView android:text="진동/무음 모드에서도 알람 스트림으로 강제 출력됩니다"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textSize="11sp" android:textColor="#9CA3AF" android:layout_marginTop="2dp"/>
                <SeekBar android:id="@+id/seek_alarm_volume"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:max="100"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 경보 동작 -->
        <TextView android:text="경보 동작" android:textStyle="bold" android:textSize="16sp"
            android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp"/>
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="8dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <TextView android:text="진동 사용" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                    <Switch android:id="@+id/switch_vibration" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
                <TextView android:text="경고 진동 시간" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp"/>
                <Spinner android:id="@+id/spinner_vib_warning" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:entries="@array/vib_warning_labels"/>
                <TextView android:text="위험 진동 반복 횟수" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp"/>
                <Spinner android:id="@+id/spinner_vib_count" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:entries="@array/vib_count_labels"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginTop="8dp">
                    <TextView android:text="경보음 사용" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                    <Switch android:id="@+id/switch_sound" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Firebase -->
        <TextView android:text="Firebase" android:textStyle="bold" android:textSize="16sp"
            android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp"/>
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="8dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:text="DB 루트 경로" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <EditText android:id="@+id/et_firebase_root" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:inputType="text"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginTop="8dp">
                    <TextView android:text="경보 자동 저장" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                    <Switch android:id="@+id/switch_auto_save" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 디버그 -->
        <TextView android:text="디버그" android:textStyle="bold" android:textSize="16sp"
            android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp"/>
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="8dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <TextView android:text="디버그 모드" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                    <Switch android:id="@+id/switch_debug" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
                <TextView android:text="테스트 시뮬레이션 RSSI (dBm)" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <SeekBar android:id="@+id/seek_sim_rssi" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1" android:max="60"/>
                    <TextView android:id="@+id/tv_sim_rssi_val" android:layout_width="64dp"
                        android:layout_height="wrap_content" android:gravity="end"/>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginTop="8dp">
                    <TextView android:text="상세 로그" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                    <Switch android:id="@+id/switch_verbose" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 판정 파라미터 (고급) — BleService 핵심 상수의 라이브 조절. 기본값 = 기존 하드코딩값 -->
        <TextView android:text="판정 파라미터 (고급)" android:textStyle="bold" android:textSize="16sp"
            android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp"/>
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="8dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">

                <TextView android:text="경보 판정·필터의 핵심 수치. 기본값은 현장 검증값이며 저장 즉시 서비스에 반영됩니다. '기본값으로 초기화'로 전체 복원."
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textSize="11sp" android:textColor="#9CA3AF"/>

                <TextView android:text="경보 판정" android:textStyle="bold"
                    android:textSize="13sp" android:textColor="#374151"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="6dp">
                    <TextView android:text="TTC 선발령 임계 (초)" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textSize="13sp" android:textColor="#111827"/>
                    <EditText android:id="@+id/et_ttc_threshold" android:layout_width="96dp" android:layout_height="wrap_content"
                        android:inputType="number|numberDecimal" android:gravity="end" android:textSize="13sp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="6dp">
                    <TextView android:text="TTC 최소 접근속도 (dBm/s)" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textSize="13sp" android:textColor="#111827"/>
                    <EditText android:id="@+id/et_min_approach_vel" android:layout_width="96dp" android:layout_height="wrap_content"
                        android:inputType="number|numberDecimal" android:gravity="end" android:textSize="13sp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="6dp">
                    <TextView android:text="Time-Gate 평상 (ms)" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textSize="13sp" android:textColor="#111827"/>
                    <EditText android:id="@+id/et_timegate_ms" android:layout_width="96dp" android:layout_height="wrap_content"
                        android:inputType="number" android:gravity="end" android:textSize="13sp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="6dp">
                    <TextView android:text="Time-Gate 코너링 (ms)" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textSize="13sp" android:textColor="#111827"/>
                    <EditText android:id="@+id/et_timegate_cornering" android:layout_width="96dp" android:layout_height="wrap_content"
                        android:inputType="number" android:gravity="end" android:textSize="13sp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="6dp">
                    <TextView android:text="Time-Gate 접근 판정속도 (dBm/s)" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textSize="13sp" android:textColor="#111827"/>
                    <EditText android:id="@+id/et_timegate_vel" android:layout_width="96dp" android:layout_height="wrap_content"
                        android:inputType="number|numberDecimal" android:gravity="end" android:textSize="13sp"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#F3F4F6" android:layout_marginTop="12dp"/>

                <TextView android:text="쿨다운·해제" android:textStyle="bold"
                    android:textSize="13sp" android:textColor="#374151"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="6dp">
                    <TextView android:text="경고 재알람 쿨다운 (ms)" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textSize="13sp" android:textColor="#111827"/>
                    <EditText android:id="@+id/et_warning_cooldown" android:layout_width="96dp" android:layout_height="wrap_content"
                        android:inputType="number" android:gravity="end" android:textSize="13sp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="6dp">
                    <TextView android:text="위험 재알람 쿨다운 (ms)" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textSize="13sp" android:textColor="#111827"/>
                    <EditText android:id="@+id/et_danger_cooldown" android:layout_width="96dp" android:layout_height="wrap_content"
                        android:inputType="number" android:gravity="end" android:textSize="13sp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="6dp">
                    <TextView android:text="격하 히스테리시스 (dB)" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textSize="13sp" android:textColor="#111827"/>
                    <EditText android:id="@+id/et_hysteresis" android:layout_width="96dp" android:layout_height="wrap_content"
                        android:inputType="number" android:gravity="end" android:textSize="13sp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="6dp">
                    <TextView android:text="이탈 중 재경보 마진 (dB)" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textSize="13sp" android:textColor="#111827"/>
                    <EditText android:id="@+id/et_departing_hysteresis" android:layout_width="96dp" android:layout_height="wrap_content"
                        android:inputType="number" android:gravity="end" android:textSize="13sp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="6dp">
                    <TextView android:text="페이드아웃 지속시간 (ms)" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textSize="13sp" android:textColor="#111827"/>
                    <EditText android:id="@+id/et_receding_clear_ms" android:layout_width="96dp" android:layout_height="wrap_content"
                        android:inputType="number" android:gravity="end" android:textSize="13sp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="6dp">
                    <TextView android:text="페이드아웃 하락폭 (dB)" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textSize="13sp" android:textColor="#111827"/>
                    <EditText android:id="@+id/et_receding_drop" android:layout_width="96dp" android:layout_height="wrap_content"
                        android:inputType="number" android:gravity="end" android:textSize="13sp"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#F3F4F6" android:layout_marginTop="12dp"/>

                <TextView android:text="충돌 기하학" android:textStyle="bold"
                    android:textSize="13sp" android:textColor="#374151"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="6dp">
                    <TextView android:text="속도 환산계수 (km/h → dBm/s)" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textSize="13sp" android:textColor="#111827"/>
                    <EditText android:id="@+id/et_closing_factor" android:layout_width="96dp" android:layout_height="wrap_content"
                        android:inputType="number|numberDecimal" android:gravity="end" android:textSize="13sp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="6dp">
                    <TextView android:text="정면충돌 접근비 (이상)" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textSize="13sp" android:textColor="#111827"/>
                    <EditText android:id="@+id/et_headon_ratio" android:layout_width="96dp" android:layout_height="wrap_content"
                        android:inputType="number|numberDecimal" android:gravity="end" android:textSize="13sp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="6dp">
                    <TextView android:text="측면 접근비 (이하)" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textSize="13sp" android:textColor="#111827"/>
                    <EditText android:id="@+id/et_side_ratio" android:layout_width="96dp" android:layout_height="wrap_content"
                        android:inputType="number|numberDecimal" android:gravity="end" android:textSize="13sp"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#F3F4F6" android:layout_marginTop="12dp"/>

                <TextView android:text="전처리 필터 (EMA)" android:textStyle="bold"
                    android:textSize="13sp" android:textColor="#374151"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="6dp">
                    <TextView android:text="상승 알파 (접근 추종)" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textSize="13sp" android:textColor="#111827"/>
                    <EditText android:id="@+id/et_ema_rise" android:layout_width="96dp" android:layout_height="wrap_content"
                        android:inputType="number|numberDecimal" android:gravity="end" android:textSize="13sp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="6dp">
                    <TextView android:text="하강 알파 (난수 무시)" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textSize="13sp" android:textColor="#111827"/>
                    <EditText android:id="@+id/et_ema_fall" android:layout_width="96dp" android:layout_height="wrap_content"
                        android:inputType="number|numberDecimal" android:gravity="end" android:textSize="13sp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="6dp">
                    <TextView android:text="D-Boost 알파 (돌진 개방)" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textSize="13sp" android:textColor="#111827"/>
                    <EditText android:id="@+id/et_ema_dboost" android:layout_width="96dp" android:layout_height="wrap_content"
                        android:inputType="number|numberDecimal" android:gravity="end" android:textSize="13sp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="6dp">
                    <TextView android:text="필터 보존 밴드 (dB)" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textSize="13sp" android:textColor="#111827"/>
                    <EditText android:id="@+id/et_preserve_band" android:layout_width="96dp" android:layout_height="wrap_content"
                        android:inputType="number" android:gravity="end" android:textSize="13sp"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#F3F4F6" android:layout_marginTop="12dp"/>

                <TextView android:text="전력·통신" android:textStyle="bold"
                    android:textSize="13sp" android:textColor="#374151"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="6dp">
                    <TextView android:text="광고 웨이크 RSSI (dBm)" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textSize="13sp" android:textColor="#111827"/>
                    <EditText android:id="@+id/et_wake_rssi" android:layout_width="96dp" android:layout_height="wrap_content"
                        android:inputType="number|numberSigned" android:gravity="end" android:textSize="13sp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="6dp">
                    <TextView android:text="신호 부재 간주 (ms)" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textSize="13sp" android:textColor="#111827"/>
                    <EditText android:id="@+id/et_stale_ms" android:layout_width="96dp" android:layout_height="wrap_content"
                        android:inputType="number" android:gravity="end" android:textSize="13sp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="6dp">
                    <TextView android:text="Firebase 저장 스로틀 (ms)" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textSize="13sp" android:textColor="#111827"/>
                    <EditText android:id="@+id/et_fb_throttle" android:layout_width="96dp" android:layout_height="wrap_content"
                        android:inputType="number" android:gravity="end" android:textSize="13sp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="6dp">
                    <TextView android:text="속도 송신 주기 (ms)" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textSize="13sp" android:textColor="#111827"/>
                    <EditText android:id="@+id/et_speed_push" android:layout_width="96dp" android:layout_height="wrap_content"
                        android:inputType="number" android:gravity="end" android:textSize="13sp"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- BLE 비콘 관리 -->
        <TextView android:text="BLE 비콘 (앱 없는 사용자 지원)" android:textStyle="bold" android:textSize="16sp"
            android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp"/>
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="8dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:id="@+id/tv_beacon_count"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="등록된 비콘: 0개  (최대 200개)"
                    android:textSize="13sp" android:textColor="#374151"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="BLE 비콘 하드웨어를 착용한 보행자도 감지 가능"
                    android:textSize="11sp" android:textColor="#9CA3AF"/>
                <Button android:id="@+id/btn_beacon_manager"
                    android:layout_width="match_parent" android:layout_height="44dp"
                    android:layout_marginTop="12dp"
                    android:text="📡  비콘 관리"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    android:backgroundTint="#F0F1F3" android:textColor="#374151"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 앱 정보 -->
        <TextView android:text="앱 정보" android:textStyle="bold" android:textSize="16sp"
            android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp"/>
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="8dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:id="@+id/tv_app_version"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="SafeAlert v1.0.6"
                            android:textSize="13sp" android:textStyle="bold" android:textColor="#111827"/>
                        <TextView
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Copyright 2024-2026 WF11 Team"
                            android:textSize="11sp" android:textColor="#9CA3AF"/>
                    </LinearLayout>
                    <Button android:id="@+id/btn_open_source_licenses"
                        android:layout_width="wrap_content" android:layout_height="40dp"
                        android:text="오픈소스"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:textColor="#374151" android:textSize="12sp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 버튼 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginTop="24dp">
            <Button android:id="@+id/btn_save" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="저장" android:backgroundTint="@color/color_device_mode"/>
            <Button android:id="@+id/btn_reset" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="기본값으로 초기화" android:backgroundTint="#9E9E9E"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
