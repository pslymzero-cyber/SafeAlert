<?xml version="1.0" encoding="utf-8"?>
<!-- [v1.0.50 #2] 다크 리워크 — 역할별 배경 사진 + 반투명 다크 카드 (기존 뷰 ID 전부 유지, 기능 불변) -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B1220">

    <!-- 역할별 배경 사진 (실행 화면 전용 — showRunningUi 가 역할에 맞춰 표시/전환) -->
    <ImageView
        android:id="@+id/iv_role_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:contentDescription="@null"
        android:visibility="gone" />

    <!-- 사진 위 어두운 스크림 (가독성 확보) -->
    <View
        android:id="@+id/view_bg_scrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/shape_bg_scrim"
        android:visibility="gone" />

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <!-- 상단 바 (액션바 없이 자체 구성) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="#C20D1424">

        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/shape_dot_green"
            android:layout_marginEnd="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SafeAlert"
            android:textSize="22sp"
            android:textStyle="bold"
            android:letterSpacing="0.04"
            android:textColor="#F1F5F9" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1FFFFFFF" />

    <!-- 스크롤 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <!-- ── 실행 중 카드 (반투명 다크) ── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_running"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#E6141B2B"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- 상태 + 시작 시각 (한 줄) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <View
                            android:layout_width="7dp" android:layout_height="7dp"
                            android:background="@drawable/shape_dot_green"
                            android:layout_marginEnd="8dp"/>
                        <TextView
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="백그라운드 실행 중"
                            android:textSize="11sp" android:textColor="#4ADE80"/>
                        <TextView
                            android:id="@+id/tv_running_since"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="11sp" android:textColor="#8B98AC"/>
                    </LinearLayout>

                    <!-- ══ 내 장비 (Local) 섹션 — 내가 송출하는 역할/상태/속도 (수신 데이터와 분리) ══ -->
                    <TextView
                        android:id="@+id/tv_local_header"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="■ 내 장비 (Local)"
                        android:textSize="12sp" android:textStyle="bold"
                        android:textColor="#60A5FA"/>

                    <!-- 이름 / ID (별도 줄, 굵게) -->
                    <TextView
                        android:id="@+id/tv_running_id"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textSize="19sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>

                    <!-- 역할 아이콘 + 모드 + TEST 버튼 (한 줄) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:id="@+id/iv_role_icon"
                            android:layout_width="46dp"
                            android:layout_height="46dp"
                            android:layout_marginEnd="12dp"
                            android:src="@drawable/ic_walker"
                            android:contentDescription="@null"/>

                        <!-- 모드 (내 역할) -->
                        <TextView
                            android:id="@+id/tv_running_mode"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"/>

                        <!-- 테스트 경보 버튼 (우측 소형 — 종 아이콘 + TEST) -->
                        <Button
                            android:id="@+id/btn_test_alert"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="62dp"
                            android:layout_height="62dp"
                            android:layout_marginStart="8dp"
                            android:insetTop="0dp" android:insetBottom="0dp"
                            android:paddingStart="0dp" android:paddingEnd="0dp"
                            android:paddingTop="11dp" android:paddingBottom="9dp"
                            android:text="TEST" android:textSize="9sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"
                            android:textColor="#D7DEE8"
                            android:drawableTop="@drawable/ic_bell"
                            android:drawableTint="#D7DEE8"
                            android:drawablePadding="2dp"
                            android:stateListAnimator="@null"
                            app:strokeColor="#56627A"
                            app:strokeWidth="1dp"
                            app:cornerRadius="14dp"/>
                    </LinearLayout>

                    <!-- [v1.0.42 Req2] 내 장비 상태/속도 — localSnapshot 에서만 갱신(수신 데이터 영향 X) -->
                    <TextView
                        android:id="@+id/tv_local_state"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/shape_local_state_box"
                        android:padding="10dp"
                        android:text="상태: 정지·일반 · 속도: 0 km/h"
                        android:textSize="13sp" android:textStyle="bold"
                        android:textColor="#7DB8F0"
                        android:fontFamily="monospace"/>

                    <!-- ══ 수신 타겟 (Target) 섹션 — 상대 기기 수신 데이터 전용 (내 장비와 분리) ══ -->
                    <TextView
                        android:id="@+id/tv_target_header"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="■ 수신 타겟 (Target)"
                        android:textSize="12sp" android:textStyle="bold"
                        android:textColor="#FB7185"/>

                    <!-- 감지 신호 목록 placeholder (목록이 비었을 때만 표시) -->
                    <TextView
                        android:id="@+id/tv_approaching"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:padding="14dp"
                        android:textSize="14sp"
                        android:textColor="#E0F0FF"
                        android:gravity="start"
                        android:lineSpacingMultiplier="1.4"
                        android:fontFamily="monospace"/>

                    <!-- 감지 기기 목록 / BLE 상태 (수신 타겟 상세 readout — detectedSnapshot 에서만 갱신)
                         배경색은 코드가 경보 레벨별로 backgroundTint 갱신 (shape 둥근 모서리 유지) -->
                    <TextView
                        android:id="@+id/tv_ble_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="서비스 시작 중..."
                        android:textSize="13sp" android:textColor="#7C93A8"
                        android:background="@drawable/shape_target_box"
                        android:backgroundTint="#E8101A2C"
                        android:padding="12dp"
                        android:lineSpacingMultiplier="1.3"
                        android:fontFamily="monospace"/>

                    <!-- 무음 인디케이터 -->
                    <TextView
                        android:id="@+id/tv_muted_indicator"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/shape_muted_box"
                        android:padding="10dp"
                        android:gravity="center"
                        android:text="🔇  일시 무음 중  —  탭하여 즉시 재개"
                        android:textSize="13sp" android:textStyle="bold"
                        android:textColor="#FCD34D"
                        android:clickable="true" android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:visibility="gone"/>

                    <!-- 중지 버튼 (밝은 회백 필 버튼) -->
                    <Button
                        android:id="@+id/btn_stop"
                        android:layout_width="match_parent" android:layout_height="52dp"
                        android:layout_marginTop="16dp"
                        android:text="중지" android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1F2937" android:backgroundTint="#E2E8F0"
                        android:stateListAnimator="@null"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                        app:cornerRadius="26dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── 모드 선택 ── -->
            <LinearLayout
                android:id="@+id/layout_select"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- 모드 선택 타이틀 + 설명 한 줄 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="모드 선택"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="#F1F5F9" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="· 역할에 맞는 모드를 선택하세요"
                        android:textSize="12sp"
                        android:textColor="#76829A" />

                </LinearLayout>

                <!-- 이름 입력 (선택) -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:hint="이름 또는 직번 (선택, 예: 홍길동)"
                    android:textColorHint="#76829A"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxCornerRadiusTopStart="12dp" app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp" app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeColor="@color/box_stroke_dark" app:hintTextColor="#8FB4E8">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_display_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPersonName"
                        android:textSize="15sp"
                        android:textColor="#F1F5F9"
                        android:imeOptions="actionDone"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- [v1.0.34] 보행자 역할 카드 -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_role_walker"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#1A2233">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:gravity="center"
                            android:background="@drawable/shape_icon_bg_green"
                            android:layout_marginEnd="14dp">
                            <ImageView
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:src="@drawable/ic_walker"
                                android:contentDescription="@null" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="보행자"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="#F1F5F9" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="도보 이동 작업자"
                                android:textSize="12sp"
                                android:textColor="#76829A" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textSize="22sp"
                            android:textColor="#4A5568"
                            android:layout_marginStart="8dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- [v1.0.34] EPJ(전동 파레트 잭) 역할 카드 -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_role_epj"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#1A2233">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:gravity="center"
                            android:background="@drawable/shape_icon_bg_gray"
                            android:layout_marginEnd="14dp">
                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@drawable/ic_epj"
                                android:contentDescription="@null" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="EPJ"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="#F1F5F9" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="전동 파레트 잭 운전자"
                                android:textSize="12sp"
                                android:textColor="#76829A" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textSize="22sp"
                            android:textColor="#4A5568"
                            android:layout_marginStart="8dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- [v1.0.34] 지게차 역할 카드 -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_role_forklift"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#1A2233">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:gravity="center"
                            android:background="@drawable/shape_icon_bg_blue"
                            android:layout_marginEnd="14dp">
                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@drawable/ic_forklift"
                                android:contentDescription="@null" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="지게차"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="#F1F5F9" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="지게차·리치 운전자"
                                android:textSize="12sp"
                                android:textColor="#76829A" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textSize="22sp"
                            android:textColor="#4A5568"
                            android:layout_marginStart="8dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- 비콘 관리 카드 (보행자 아래) -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_beacon"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#1A2233">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:gravity="center"
                            android:background="@drawable/shape_icon_bg_gray"
                            android:layout_marginEnd="14dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="📡"
                                android:textSize="20sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="비콘 관리"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="#F1F5F9" />
                            <TextView
                                android:id="@+id/tv_beacon_summary"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="iOS·앱 없는 보행자 감지 설정"
                                android:textSize="12sp"
                                android:textColor="#76829A" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textSize="22sp"
                            android:textColor="#4A5568"
                            android:layout_marginStart="8dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- BLE 설정 카드 (비콘 아래) -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_ble_settings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true" android:focusable="true"
                    app:cardCornerRadius="18dp" app:cardElevation="0dp"
                    app:cardBackgroundColor="#1A2233">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp" android:gravity="center_vertical">
                        <LinearLayout android:layout_width="44dp" android:layout_height="44dp"
                            android:gravity="center" android:background="@drawable/shape_icon_bg_blue"
                            android:layout_marginEnd="14dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="📶" android:textSize="20sp"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="BLE 설정" android:textSize="15sp"
                                android:textStyle="bold" android:textColor="#F1F5F9"/>
                            <TextView android:id="@+id/tv_ble_mode_summary"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_marginTop="2dp" android:textSize="12sp" android:textColor="#76829A"/>
                        </LinearLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="›" android:textSize="22sp" android:textColor="#4A5568"
                            android:layout_marginStart="8dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Settings 카드 (PIN 전용) -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_settings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#161D2B">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:gravity="center"
                            android:background="@drawable/shape_icon_bg_gray"
                            android:layout_marginEnd="14dp">
                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@android:drawable/ic_menu_preferences"
                                android:contentDescription="Settings"
                                android:tint="#8B98AC" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="개발자 설정"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="#C3CDDC" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="PIN 입력 필요"
                                android:textSize="12sp"
                                android:textColor="#76829A" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textSize="22sp"
                            android:textColor="#4A5568"
                            android:layout_marginStart="8dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- 권한 경고 -->
            <LinearLayout
                android:id="@+id/layout_permission_warning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/shape_warning_bg"
                android:orientation="horizontal"
                android:padding="14dp"
                android:gravity="center_vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_permission_msg"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="12sp"
                    android:textColor="#FCD34D" />

                <TextView
                    android:id="@+id/btn_grant"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="허용"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#FBBF24"
                    android:padding="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:visibility="gone" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- 하단 고정: 버전 + 크레딧 (코드에서 BuildConfig.VERSION_NAME으로 동적 설정) -->
    <TextView
        android:id="@+id/tv_version_footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="10dp"
        android:paddingBottom="14dp"
        android:gravity="center"
        android:text="v1.0.0  ·  Created by Ian"
        android:textSize="11sp"
        android:textColor="#66738C"
        android:letterSpacing="0.05"
        android:background="#C20D1424" />

</LinearLayout>

    <!-- [v1.1.1] 시작 스플래시 — 1.5초 표시 후 MainActivity 가 페이드아웃. clickable 로 하단 UI
         터치 차단, 화면 재생성(회전 등) 시에는 onCreate 가 즉시 숨김 -->
    <ImageView
        android:id="@+id/iv_splash"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_splash"
        android:background="#0B1220"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="@null" />

</FrameLayout>
