<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F6F8"
    android:fitsSystemWindows="true">

    <!-- 상단 바 (액션바 없이 자체 구성) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="#FFFFFF">

        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/shape_dot_green"
            android:layout_marginEnd="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SafeAlert"
            android:textSize="22sp"
            android:textStyle="bold"
            android:letterSpacing="0.04"
            android:textColor="#111827" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EAECF0" />

    <!-- 스크롤 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <!-- ── 실행 중 카드 ── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_running"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#EBF5FB"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- 상태 + 시작 시각 (한 줄) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <View
                            android:layout_width="7dp" android:layout_height="7dp"
                            android:background="@drawable/shape_dot_green"
                            android:layout_marginEnd="8dp"/>
                        <TextView
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="백그라운드 실행 중"
                            android:textSize="11sp" android:textColor="#5B8FA8"/>
                        <TextView
                            android:id="@+id/tv_running_since"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="11sp" android:textColor="#8AAFC4"/>
                    </LinearLayout>

                    <!-- 이름 / ID (별도 줄, 굵게) -->
                    <TextView
                        android:id="@+id/tv_running_id"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#0D1B2A"/>

                    <!-- 모드 -->
                    <TextView
                        android:id="@+id/tv_running_mode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#0D1B2A"/>

                    <!-- 감지 신호 목록 (RSSI 강한 순, 최대 10개) -->
                    <TextView
                        android:id="@+id/tv_approaching"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:padding="14dp"
                        android:textSize="14sp"
                        android:textColor="#E0F0FF"
                        android:gravity="start"
                        android:lineSpacingMultiplier="1.4"
                        android:fontFamily="monospace"
                        android:visibility="gone"/>

                    <!-- 무음 인디케이터 -->
                    <TextView
                        android:id="@+id/tv_muted_indicator"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="#FEF3C7"
                        android:padding="10dp"
                        android:gravity="center"
                        android:text="🔇  일시 무음 중  —  탭하여 즉시 재개"
                        android:textSize="13sp" android:textStyle="bold"
                        android:textColor="#92400E"
                        android:clickable="true" android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:visibility="gone"/>

                    <!-- 테스트 경보 버튼 -->
                    <Button
                        android:id="@+id/btn_test_alert"
                        android:layout_width="match_parent" android:layout_height="44dp"
                        android:layout_marginTop="14dp"
                        android:text="🔔 테스트 경보" android:textSize="13sp"
                        android:textColor="#B45309" android:backgroundTint="#FEF3C7"
                        android:stateListAnimator="@null"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                        app:cornerRadius="10dp"/>

                    <!-- 중지 버튼 -->
                    <Button
                        android:id="@+id/btn_stop"
                        android:layout_width="match_parent" android:layout_height="46dp"
                        android:layout_marginTop="8dp"
                        android:text="중지" android:textSize="14sp"
                        android:textColor="#374151" android:backgroundTint="#DDE6ED"
                        android:stateListAnimator="@null"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                        app:cornerRadius="12dp"/>

                    <!-- BLE 상태 로그 (중지 버튼 아래, 작은 글씨) -->
                    <TextView
                        android:id="@+id/tv_ble_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="서비스 시작 중..."
                        android:textSize="13sp" android:textColor="#5B8FA8"
                        android:background="#DDE9F0"
                        android:padding="12dp"
                        android:lineSpacingMultiplier="1.3"
                        android:fontFamily="monospace"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── 모드 선택 ── -->
            <LinearLayout
                android:id="@+id/layout_select"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- 모드 선택 타이틀 + 설명 한 줄 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="모드 선택"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="#0D1B2A" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="· 역할에 맞는 모드를 선택하세요"
                        android:textSize="12sp"
                        android:textColor="#9CA3AF" />

                </LinearLayout>

                <!-- 이름 입력 (선택) -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:hint="이름 또는 직번 (선택, 예: 홍길동)"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxCornerRadiusTopStart="12dp" app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp" app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeColor="#E5E7EB" app:hintTextColor="#9CA3AF">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_display_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPersonName"
                        android:textSize="15sp"
                        android:imeOptions="actionDone"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- 장비 작업자 카드 -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_device"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:gravity="center"
                            android:background="@drawable/shape_icon_bg_blue"
                            android:layout_marginEnd="14dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🚛"
                                android:textSize="20sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="장비 작업자"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="#0D1B2A" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="리치 등 장비 운전자"
                                android:textSize="12sp"
                                android:textColor="#9CA3AF" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textSize="22sp"
                            android:textColor="#C8CBD2"
                            android:layout_marginStart="8dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- 보행자 카드 -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_walker"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:gravity="center"
                            android:background="@drawable/shape_icon_bg_green"
                            android:layout_marginEnd="14dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🚶"
                                android:textSize="20sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="보행자"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="#0D1B2A" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="도보 이동 작업자"
                                android:textSize="12sp"
                                android:textColor="#9CA3AF" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textSize="22sp"
                            android:textColor="#C8CBD2"
                            android:layout_marginStart="8dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- 비콘 관리 카드 (보행자 아래) -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_beacon"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:gravity="center"
                            android:background="@drawable/shape_icon_bg_gray"
                            android:layout_marginEnd="14dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="📡"
                                android:textSize="20sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="비콘 관리"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="#0D1B2A" />
                            <TextView
                                android:id="@+id/tv_beacon_summary"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="iOS·앱 없는 보행자 감지 설정"
                                android:textSize="12sp"
                                android:textColor="#9CA3AF" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textSize="22sp"
                            android:textColor="#C8CBD2"
                            android:layout_marginStart="8dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- BLE 설정 카드 (비콘 아래) -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_ble_settings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true" android:focusable="true"
                    app:cardCornerRadius="18dp" app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp" android:gravity="center_vertical">
                        <LinearLayout android:layout_width="44dp" android:layout_height="44dp"
                            android:gravity="center" android:background="@drawable/shape_icon_bg_blue"
                            android:layout_marginEnd="14dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="📶" android:textSize="20sp"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="BLE 설정" android:textSize="15sp"
                                android:textStyle="bold" android:textColor="#0D1B2A"/>
                            <TextView android:id="@+id/tv_ble_mode_summary"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_marginTop="2dp" android:textSize="12sp" android:textColor="#9CA3AF"/>
                        </LinearLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="›" android:textSize="22sp" android:textColor="#C8CBD2"
                            android:layout_marginStart="8dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Settings 카드 (PIN 전용) -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_settings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#F0F1F3">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:gravity="center"
                            android:background="@drawable/shape_icon_bg_gray"
                            android:layout_marginEnd="14dp">
                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@android:drawable/ic_menu_preferences"
                                android:contentDescription="Settings"
                                android:tint="#6B7280" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="개발자 설정"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="#4B5563" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="PIN 입력 필요"
                                android:textSize="12sp"
                                android:textColor="#9CA3AF" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textSize="22sp"
                            android:textColor="#C8CBD2"
                            android:layout_marginStart="8dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- 권한 경고 -->
            <LinearLayout
                android:id="@+id/layout_permission_warning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/shape_warning_bg"
                android:orientation="horizontal"
                android:padding="14dp"
                android:gravity="center_vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_permission_msg"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="12sp"
                    android:textColor="#92400E" />

                <TextView
                    android:id="@+id/btn_grant"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="허용"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#D97706"
                    android:padding="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:visibility="gone" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- 하단 고정: 버전 + 크레딧 (코드에서 BuildConfig.VERSION_NAME으로 동적 설정) -->
    <TextView
        android:id="@+id/tv_version_footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="10dp"
        android:paddingBottom="14dp"
        android:gravity="center"
        android:text="v1.0.0  ·  Created by Ian"
        android:textSize="11sp"
        android:textColor="#C4C9D4"
        android:letterSpacing="0.05"
        android:background="#FFFFFF" />

</LinearLayout>

<!-- 경보 테두리 오버레이 (터치 통과) -->
<View
    android:id="@+id/alert_overlay"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/shape_danger_border"
    android:clickable="false"
    android:focusable="false"
    android:visibility="gone" />

</FrameLayout>
